{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://batch-spec.dev/schema/expansion.schema.json",
  "title": "batch-spec expansion and language semantics",
  "type": "object",
  "required": ["version", "valid_modifiers", "valid_modifier_chars"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "valid_modifiers": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "valid_modifier_chars": {
      "type": "string",
      "pattern": "^[a-z]+$"
    },
    "valid_parameter_patterns": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "invalid_combinations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reason"],
        "properties": {
          "pattern": { "type": "string" },
          "modifiers": { "type": "string" },
          "reason": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "valid_combined_examples": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "delayed_expansion": {
      "type": "object",
      "required": ["pattern", "requires_setlocal"],
      "properties": {
        "pattern": { "type": "string", "minLength": 1 },
        "requires_setlocal": { "type": "boolean" },
        "enable_keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "disable_keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "enable_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "disable_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "substring_pattern": { "type": "string" },
        "replacement_pattern": { "type": "string" },
        "digit_leading_names": { "type": "string" },
        "exclamation_escaping": { "type": "string" }
      },
      "additionalProperties": false
    },
    "for_loop_variables": {
      "type": "object",
      "required": ["batch_file_prefix", "command_line_prefix"],
      "properties": {
        "batch_file_prefix": { "type": "string", "const": "%%" },
        "command_line_prefix": { "type": "string", "const": "%" },
        "letter_charset": { "type": "string" },
        "letter_charset_notes": { "type": "string" },
        "case_sensitive": { "type": "string" }
      },
      "additionalProperties": false
    },
    "for_forms": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "slash_d": { "type": "string", "minLength": 1 },
        "slash_r": { "type": "string", "minLength": 1 },
        "slash_l": { "type": "string", "minLength": 1 },
        "slash_f": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "for_f": {
      "type": "object",
      "required": ["description", "options"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "options": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "option_details": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "useback_synonym": { "type": "string" },
        "consecutive_delims": { "type": "string" },
        "input_forms": { "type": "string" }
      },
      "additionalProperties": false
    },
    "caret_escape": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "call_doubling": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "double_percent": {
      "type": "object",
      "properties": {
        "for_body_rule": { "type": "string" },
        "echo_literal_rule": { "type": "string" },
        "batch_vs_cmdline": { "type": "string" }
      },
      "additionalProperties": false
    },
    "string_operations": {
      "type": "object",
      "properties": {
        "substring_pattern": { "type": "string" },
        "replacement_pattern": { "type": "string" },
        "description": { "type": "string" },
        "negative_offsets": { "type": "string" },
        "empty_defined_substring_batveat": { "type": "string" },
        "star_prefix_replace": { "type": "string" }
      },
      "additionalProperties": false
    },
    "path_search_modifier": {
      "type": "object",
      "properties": {
        "pattern": { "type": "string" },
        "description": { "type": "string" },
        "example": { "type": "string" }
      },
      "additionalProperties": false
    },
    "percent_tilde_notes": {
      "type": "object",
      "properties": {
        "bare_quote_strip": { "type": "string" },
        "multi_digit_parameter": { "type": "string" }
      },
      "additionalProperties": false
    },
    "set_a": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "unary_operators": {
          "type": "array",
          "items": { "type": "string" }
        },
        "binary_operators": {
          "type": "array",
          "items": { "type": "string" }
        },
        "assignment_operators": {
          "type": "array",
          "items": { "type": "string" }
        },
        "grouping": { "type": "string" },
        "expression_separator": { "type": "string" },
        "hex_literal": { "type": "string" },
        "octal_literal": { "type": "string" },
        "modulo_in_batch": { "type": "string" },
        "quoting_rule": { "type": "string" },
        "undefined_as_zero": { "type": "string" },
        "bare_names": { "type": "string" },
        "integer_range": { "type": "string" },
        "spaces_around_assignment": { "type": "string" },
        "interactive_display": { "type": "string" }
      },
      "additionalProperties": false
    },
    "set_assignment": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "setlocal_options": {
      "type": "object",
      "properties": {
        "flags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "nesting_limit": { "type": "string" },
        "implied_endlocal": { "type": "string" },
        "argument_errorlevel": { "type": "string" }
      },
      "additionalProperties": false
    },
    "errorlevel": {
      "type": "object",
      "properties": {
        "if_form": { "type": "string" },
        "variable_form": { "type": "string" },
        "env_var_shadowing": { "type": "string" }
      },
      "additionalProperties": false
    },
    "cmdextversion": {
      "type": "object",
      "properties": {
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "dynamic_environment_variables": {
      "type": "object",
      "required": ["description", "names"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "names": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 },
          "minProperties": 1
        },
        "extensions_required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "keyword_boundaries": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "reject_glue_after_keyword": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "if_forms": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "base_forms": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "extension_forms": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "compare_ops": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "compare_ops_notes": { "type": "string" },
        "defined_notes": { "type": "string" },
        "else_same_line": { "type": "string" }
      },
      "additionalProperties": false
    },
    "if_block_parentheses": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "command_chaining": {
      "type": "object",
      "required": ["description", "operators"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "operators": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 },
          "minProperties": 1
        },
        "grouping": { "type": "string" }
      },
      "additionalProperties": false
    },
    "batch_parameters": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "percent_star": { "type": "string" },
        "percent_star_and_shift": { "type": "string" },
        "shift_n": { "type": "string" },
        "percent_zero": { "type": "string" }
      },
      "additionalProperties": false
    },
    "call_goto": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "call_label": { "type": "string" },
        "goto_eof": { "type": "string" }
      },
      "additionalProperties": false
    },
    "exit_semantics": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "exit_b": { "type": "string" }
      },
      "additionalProperties": false
    },
    "remarks": {
      "type": "object",
      "properties": {
        "rem": { "type": "string" },
        "double_colon": { "type": "string" },
        "rem_vs_label": { "type": "string" }
      },
      "additionalProperties": false
    },
    "redirection": {
      "type": "object",
      "required": ["description", "operators"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "operators": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 },
          "minProperties": 1
        },
        "examples": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "nul_suppress": { "type": "string" },
        "group_redirect": { "type": "string" }
      },
      "additionalProperties": false
    },
    "paren_block_expansion": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "percent_at_parse": { "type": "string" },
        "delayed_at_execution": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
