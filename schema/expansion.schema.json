    "valid_modifiers": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "valid_modifier_chars": {
      "type": "string",
      "pattern": "^[a-z]+$"
    },
    "valid_parameter_patterns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "invalid_combinations": {
      "type": "array",
