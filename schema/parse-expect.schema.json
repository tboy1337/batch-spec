{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://batch-spec.dev/schema/parse-expect.schema.json",
  "title": "batch-spec parse corpus expect.json",
  "type": "object",
  "required": ["description", "parse"],
  "properties": {
    "description": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "parse": {
      "type": "object",
      "properties": {
        "should_parse": {
          "type": "boolean"
        },
        "expect_syntax_errors": {
          "type": "boolean"
        },
        "top_level_statement": {
          "type": "string",
          "minLength": 1,
          "description": "Rule name of the last script-level statement (not nested in IF/FOR/group blocks), e.g. ifStmt, forStmt."
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": { "expect_syntax_errors": { "const": true } },
            "required": ["expect_syntax_errors"]
          },
          "then": {
            "not": {
              "properties": { "should_parse": { "const": true } },
              "required": ["should_parse"]
            }
          }
        },
        {
          "if": {
            "properties": { "should_parse": { "const": false } },
            "required": ["should_parse"]
          },
          "then": {
            "not": {
              "properties": { "expect_syntax_errors": { "const": true } },
              "required": ["expect_syntax_errors"]
            }
          }
        }
      ]
    }
  },
  "additionalProperties": false
}
