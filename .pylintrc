[MASTER]
init-hook=import sys; from pathlib import Path; root = Path.cwd(); sys.path[:0] = [str(root / "scripts"), str(root / "conformance"), str(root / "generated" / "python")]
py-version=3.12
jobs=0
ignore-paths=^generated/

[MESSAGES CONTROL]
disable=missing-module-docstring,
        missing-function-docstring,
        too-few-public-methods,
        import-outside-toplevel,
        wrong-import-position

[FORMAT]
max-line-length=88

[DESIGN]
max-args=10